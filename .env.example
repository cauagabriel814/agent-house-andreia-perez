# ==========================================
# Andreia - Agente IA Residere
# Copie este arquivo para .env e preencha
# ==========================================

# --- Aplicacao ---
APP_NAME=andreia-residere
APP_ENV=development
DEBUG=true

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=andreia_db
POSTGRES_USER=andreia
POSTGRES_PASSWORD=andreia_secret
DATABASE_URL=postgresql+asyncpg://andreia:andreia_secret@localhost:5432/andreia_db

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=andreia
RABBITMQ_PASSWORD=andreia_secret
RABBITMQ_URL=amqp://andreia:andreia_secret@localhost:5672/

# --- UAZAPI (WhatsApp) ---
UAZAPI_BASE_URL=https://sua-instancia.uazapi.com
UAZAPI_TOKEN=seu_token_aqui
UAZAPI_INSTANCE_ID=sua_instancia

# --- Webhook ---
WEBHOOK_SECRET=seu_webhook_secret_aqui

# --- LLM ---
OPENAI_API_KEY=sk-...
# ou ANTHROPIC_API_KEY=sk-ant-...

# --- LangSmith ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls_...
LANGCHAIN_PROJECT=andreia-residere

# --- CRM generico (legado, substituido pelo KOMMO abaixo) ---
CRM_BASE_URL=
CRM_API_KEY=
CRM_PIPELINE_ID=

# --- KOMMO CRM ---
# So o subdominio, sem .kommo.com (ex: "suaempresa" para suaempresa.kommo.com)
KOMMO_SUBDOMAIN=
# Token de longa duracao gerado em: Configuracoes > Integracoes > API > Token
KOMMO_ACCESS_TOKEN=
# ID numerico do pipeline onde os negocios serao criados
KOMMO_PIPELINE_ID=
# JSON mapeando stages internos para IDs numericos dos stages no KOMMO
# Obtenha os IDs em: GET https://{subdomain}.kommo.com/api/v4/leads/pipelines
KOMMO_STAGE_MAP={"lead_novo": 0, "em_qualificacao": 0, "oportunidade_quente": 0, "follow_up_programado": 0, "nutricao_ativa": 0, "proposta_enviada": 0, "visita_agendada": 0}

# --- Email Marketing (Feature 17) ---
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=seu_email@gmail.com
EMAIL_SMTP_PASSWORD=sua_senha_de_app
EMAIL_FROM=seu_email@gmail.com
EMAIL_FROM_NAME=Residere Imoveis

# --- Agendamento / Agenda (Feature 17) ---
# URL base da API do sistema de agenda (ex: https://agenda.empresa.com/api)
APPOINTMENT_BASE_URL=
APPOINTMENT_API_KEY=

# --- Notificacoes para Corretores (Feature 17) ---
# Telefones dos corretores separados por virgula (formato: 5565999991111)
CORRETOR_PHONES=5565999991111,5565999992222
