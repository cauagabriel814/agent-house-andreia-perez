{
  "info": {
    "name": "Residere API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    console.log('Token salvo com sucesso.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin@residere.com", "type": "text" },
                { "key": "password", "value": "admin123", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Registrar primeiro admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@residere.com\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/first",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", "first"]
            }
          }
        },
        {
          "name": "Registrar corretor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"email\": \"joao@residere.com\",\n  \"password\": \"senha123\",\n  \"role\": \"corretor\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        }
      ]
    },
    {
      "name": "Métricas",
      "item": [
        {
          "name": "Dashboard de KPIs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/metrics/dashboard",
              "host": ["{{base_url}}"],
              "path": ["metrics", "dashboard"]
            }
          }
        },
        {
          "name": "Métricas operacionais",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/metrics",
              "host": ["{{base_url}}"],
              "path": ["metrics"]
            }
          }
        }
      ]
    },
    {
      "name": "Usuários",
      "item": [
        {
          "name": "Meu perfil",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/users/me",
              "host": ["{{base_url}}"],
              "path": ["users", "me"]
            }
          }
        },
        {
          "name": "Listar usuários",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          }
        }
      ]
    },
    {
      "name": "Imóveis",
      "item": [
        {
          "name": "Listar imóveis",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/properties",
              "host": ["{{base_url}}"],
              "path": ["admin", "properties"]
            }
          }
        },
        {
          "name": "Buscar por código",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/properties/by-code/CODIGO_AQUI",
              "host": ["{{base_url}}"],
              "path": ["admin", "properties", "by-code", "CODIGO_AQUI"]
            }
          }
        },
        {
          "name": "Criar imóvel",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"AP001\",\n  \"tipo\": \"Apartamento\",\n  \"situacao\": \"Pronto\",\n  \"finalidade\": \"Venda\",\n  \"bairro\": \"Centro\",\n  \"valor\": 850000,\n  \"suites\": 2,\n  \"vagas\": 1,\n  \"area_privativa\": 80.0,\n  \"corretor_responsavel\": \"João Silva\",\n  \"disponivel\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/properties",
              "host": ["{{base_url}}"],
              "path": ["admin", "properties"]
            }
          }
        },
        {
          "name": "Exportar CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/properties/export/csv",
              "host": ["{{base_url}}"],
              "path": ["admin", "properties", "export", "csv"]
            }
          }
        }
      ]
    },
    {
      "name": "Chat (teste)",
      "item": [
        {
          "name": "Enviar mensagem ao agente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"5511999999999\",\n  \"message\": \"Olá, tenho interesse em vender meu apartamento\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/chat",
              "host": ["{{base_url}}"],
              "path": ["chat"]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    }
  ]
}
